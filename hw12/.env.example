# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# LLM Parameters (override model presets)
# OLLAMA_TEMPERATURE=0.1
# OLLAMA_NUM_PREDICT=4096
# OLLAMA_TOP_P=0.9
# OLLAMA_TOP_K=40
# OLLAMA_REQUEST_TIMEOUT=300

# Model-specific presets (automatic, no need to set manually):
# llama3.1:8b:     temp=0.1, num_predict=4096, top_p=0.9, top_k=40
# qwen3.5:9b-q4_K_M: temp=0.1, num_predict=4096, top_p=0.85, top_k=50

# Flask Configuration
FLASK_PORT=5000
FLASK_DEBUG=false

# Debug Logging
DEBUG=false