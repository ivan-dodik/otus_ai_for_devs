{
  "servers": {
    "openbcm-helper": {
      "type": "stdio",
      "command": "uv",
      "args": ["run", "python", "-m", "src"],
      "env": {
        "OPENBCM_SDK_PATH": "/path/to/openbcm-sdk-6.5.27",
        "OPENBCM_MCP_LOG_LEVEL": "INFO",
        "OPENBCM_MCP_CACHE_DIR": "./cache"
      }
    }
  }
}